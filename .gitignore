# Virtual environment
venv/
.venv/

# Cursor
.cursor/

# Local config (settings now in browser sessionStorage for multi-user hosting)
config.json

# Environment variables (secrets)
.env
.env.*
!.env.example
!.env.template

# Generic secret / credential material
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
secrets/
secret*/
*.tfvars
*.tfstate
*.tfstate.*

# Python bytecode
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Terraform working directory and build artifacts
infra/.terraform/
infra/lambda/*.zip
infra/terraform.tfvars

# GCP service account credentials (never commit)
*-gcp-key.json
*gcp-service-account.json
terraform-gcp-key.json

# Local metrics / log artifacts (generated by tools/collect_metrics.py)
*.log
tools/*_metrics.json
gcp_metrics.json
*.wav
data/custom_words.runtime.v1.json

# Local face-rec encodings (biometric data — never commit)
faces/
**/.myra/faces.pkl
